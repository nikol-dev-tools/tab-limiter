{
  "manifest_version": 3,
  "name": "Tab Limiter — Stay Focused",
  "short_name": "Tab Limiter",
  "version": "1.0.0",
  "description": "Limit open tabs to stay focused. Set your max tab count and keep your browser clean. Simple, fast, distraction-free.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Tab Limiter"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ]
}
